# Nacos config center (safe to commit — placeholder values)
# 如果 NACOS_PASSWORD 为空，则跳过 Nacos，完全使用本地 .env + 代码默认值
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=changeme
NACOS_DATA_ID=post-service-dev.yaml
NACOS_GROUP=DEFAULT_GROUP
NACOS_NAMESPACE=

# -----------------------------------------------------------------------------
# PostgreSQL (asyncpg)
# 完整 URL 优先级高于下面独立字段；留空或注释掉则从 Nacos 读取
# POSTGRES_URL=postgresql+asyncpg://user:password@host:port/db
# -----------------------------------------------------------------------------
# POSTGRES_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/dating_dev
# SQL_ECHO=false
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Redis
# 完整 REDIS_URL 优先级高于独立字段
# REDIS_URL=redis://:password@host:port/db
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_DECODE_RESPONSES=true
APP_CACHE_KEY_PREFIX=qidian:

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio-api.example.com
# MINIO_ACCESS_KEY=your_minio_access_key
# MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=true
MINIO_BUCKET_NAME=dating-qidian
MINIO_CDN_BASE_URL=https://minio.example.com

# -----------------------------------------------------------------------------
# RocketMQ 5.x (gRPC Proxy)
# -----------------------------------------------------------------------------
ROCKETMQ_NAMESERVER_ADDR=127.0.0.1:9876
# Proxy endpoints，多个用逗号分隔；不配置时自动从 nameserver 主机名推断 8081
ROCKETMQ_ENDPOINTS=127.0.0.1:8081
ROCKETMQ_ACCESS_KEY=
ROCKETMQ_SECRET_KEY=
ROCKETMQ_TOPIC=dev-qidian-post-sevices
ROCKETMQ_TAG=POST_FANOUT
ROCKETMQ_CONSUMER_GROUP=dev-qidian-consumer
ROCKETMQ_PRODUCER_GROUP=dev-qidian-post-service-producer
ROCKETMQ_ENABLED=true

# -----------------------------------------------------------------------------
# Loki 日志推送（本地开发可保留默认值）
# -----------------------------------------------------------------------------
LOKI_PUSH_URL=http://localhost:3100/loki/api/v1/push
